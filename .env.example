# ===================================
# AI CMO - Environment Variables
# ===================================
# Copy this file to .env.local and fill in your keys
# IMPORTANT: Never commit .env.local to git!

# ============ AUTH ============
# Choose either Clerk OR Supabase Auth (recommended: Supabase for all-in-one)

# Supabase (Auth + Database) - https://supabase.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Clerk (Alternative Auth) - https://clerk.com
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx

# ============ AI / LLM ============
# Backend proxy endpoint (recommended for security)
# Create a serverless function (Vercel/Cloudflare) that proxies OpenAI/Claude
VITE_AI_API_ENDPOINT=https://your-api.vercel.app/api/ai

# Direct API keys (NOT RECOMMENDED for production - exposed to client)
# Only use for development/testing
VITE_OPENAI_API_KEY=sk-xxxxxxxxxxxx
VITE_ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# ============ PAYMENTS ============
# Stripe - https://stripe.com
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx

# Stripe Price IDs (create products in Stripe dashboard first)
VITE_STRIPE_PRICE_PRO=price_xxxxxxxxxxxx
VITE_STRIPE_PRICE_MAX=price_xxxxxxxxxxxx
VITE_STRIPE_PRICE_FOUNDER=price_xxxxxxxxxxxx

# Backend endpoint for Stripe Checkout session creation
VITE_STRIPE_CHECKOUT_ENDPOINT=https://your-api.vercel.app/api/checkout

# ============ EMAIL ============
# Resend - https://resend.com
# Backend endpoint required (Resend API needs server-side)
VITE_EMAIL_API_ENDPOINT=https://your-api.vercel.app/api/email

# ============ REAL DATA APIS ============

# Google PageSpeed Insights - https://developers.google.com/speed
VITE_GOOGLE_PAGESPEED_API_KEY=your-google-api-key

# DataForSEO (alternative SEO data) - https://dataforseo.com
VITE_DATAFORSEO_LOGIN=your-email
VITE_DATAFORSEO_PASSWORD=your-password

# SerpAPI (Google search results) - https://serpapi.com
VITE_SERPAPI_KEY=your-serpapi-key

# Reddit API - https://www.reddit.com/prefs/apps
VITE_REDDIT_CLIENT_ID=xxxxxxxxxxxx
VITE_REDDIT_CLIENT_SECRET=xxxxxxxxxxxx

# Hacker News - No API key needed (public API)

# Twitter/X API - https://developer.twitter.com
VITE_TWITTER_BEARER_TOKEN=your-bearer-token

# LinkedIn API - https://developer.linkedin.com
VITE_LINKEDIN_CLIENT_ID=xxxxxxxxxxxx
VITE_LINKEDIN_CLIENT_SECRET=xxxxxxxxxxxx

# ============ ANALYTICS ============
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxx
VITE_POSTHOG_HOST=https://app.posthog.com
